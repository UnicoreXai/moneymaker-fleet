# ============================================================================
# moneymaker-fleet — example environment file
# ----------------------------------------------------------------------------
# Copy to `.env` (untracked) and fill in. Anything left as a placeholder will
# fail loud at startup, never silent.
# ============================================================================

# --- Wallet (Layer 1 on-chain collector) ----------------------------------
# Your payout wallet. ALL incoming token + native transfers to this address
# are classified by sender and counted as service revenue.
WALLET_EVM=0x0000000000000000000000000000000000000000
WALLET_SOL=YOUR_BASE58_SOLANA_ADDRESS_HERE

# --- Block-explorer keys --------------------------------------------------
# Etherscan v2 unified key (covers ETH/Polygon/Arbitrum/Optimism/Base/BSC).
# Free tier is 5 req/s, plenty for a 30-day backfill.
ETHERSCAN_KEY=

# Optional. Public Solana RPC works as a fallback.
SOLSCAN_KEY=

# --- Dashboard / forum back end -------------------------------------------
# Where the Layer 1/2 collectors POST their classified rows.
DASHBOARD_BASE=https://dashboard.example.com
# Shared secret. Workers send `X-Forum-Secret: <hex>` and the collectors send
# the same header on /api/realized-revenue POSTs. 32 hex chars min.
FORUM_SECRET=

# --- Hermes worker swarm (optional) ---------------------------------------
# OpenRouter API key, single account, scoped per-worker by spend cap.
OPENROUTER_KEY_PATH=/etc/mm-agent/openrouter.key
# Default model used by the per-node mm-agent. Override per-node in
# config/hermes/node_model_assignment.json.
MM_DEFAULT_MODEL=deepseek/deepseek-chat-v3.1
# Daily fleet-wide spend cap in USD. spend_cap.sh aborts above this.
MM_DAILY_CAP_USD=10.00

# --- Scraping API service (optional) --------------------------------------
SCRAPING_API_KEYS_PATH=/etc/scraping-api/keys.json
SCRAPING_API_PROXIES_PATH=/etc/scraping-api/fleet_proxies.json
SCRAPING_API_LOG_PATH=/var/log/scraping-api/requests.jsonl

# --- Lookback window (Layer 1) --------------------------------------------
LOOKBACK_DAYS=30
LOG_LEVEL=INFO
